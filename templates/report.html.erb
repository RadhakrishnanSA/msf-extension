<!DOCTYPE html>
<html lang="en">
<head>
  <title>MME Report - <%= metadata[:target] %></title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-primary: #0a0e1a;
      --bg-secondary: #111827;
      --bg-card: rgba(17, 24, 39, 0.8);
      --bg-elevated: rgba(30, 41, 59, 0.6);
      --border: rgba(255, 255, 255, 0.06);
      --border-hover: rgba(255, 255, 255, 0.12);
      --text-primary: #f1f5f9;
      --text-secondary: #94a3b8;
      --text-muted: #64748b;
      --accent-blue: #3b82f6;
      --accent-cyan: #06b6d4;
      --accent-purple: #8b5cf6;
      --accent-green: #10b981;
      --accent-red: #ef4444;
      --accent-orange: #f97316;
      --accent-yellow: #eab308;
      --gradient-header: linear-gradient(135deg, #0f172a 0%, #1e1b4b 50%, #0f172a 100%);
      --gradient-accent: linear-gradient(135deg, #3b82f6, #8b5cf6);
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--bg-primary);
      color: var(--text-primary);
      min-height: 100vh;
      line-height: 1.6;
    }

    /* Header */
    .header {
      background: var(--gradient-header);
      border-bottom: 1px solid var(--border);
      padding: 40px 0;
      position: relative;
      overflow: hidden;
    }
    .header::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle at 30% 50%, rgba(59, 130, 246, 0.08) 0%, transparent 50%),
                  radial-gradient(circle at 70% 50%, rgba(139, 92, 246, 0.06) 0%, transparent 50%);
      animation: pulse 8s ease-in-out infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 0.5; }
      50% { opacity: 1; }
    }
    .header-inner {
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 32px;
      position: relative;
      z-index: 1;
    }
    .header-top {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 8px;
    }
    .header-logo {
      width: 48px;
      height: 48px;
      background: var(--gradient-accent);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 24px;
      box-shadow: 0 0 30px rgba(59, 130, 246, 0.3);
    }
    .header h1 {
      font-size: 28px;
      font-weight: 800;
      background: linear-gradient(135deg, #60a5fa, #a78bfa, #60a5fa);
      background-size: 200% 200%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: shimmer 3s ease-in-out infinite;
    }
    @keyframes shimmer {
      0%, 100% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
    }
    .header-sub { color: var(--text-secondary); font-size: 15px; font-weight: 400; }
    .header-meta {
      display: flex;
      gap: 24px;
      margin-top: 20px;
      flex-wrap: wrap;
    }
    .header-meta-item {
      display: flex;
      align-items: center;
      gap: 8px;
      color: var(--text-secondary);
      font-size: 13px;
    }
    .header-meta-item span { color: var(--text-primary); font-weight: 600; }

    /* Container */
    .container { max-width: 1280px; margin: 0 auto; padding: 32px; }

    /* Cards */
    .card {
      background: var(--bg-card);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px;
      margin-bottom: 24px;
      transition: border-color 0.3s ease;
    }
    .card:hover { border-color: var(--border-hover); }
    .card-title {
      font-size: 18px;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 20px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .card-title .icon { font-size: 20px; }

    /* Stats Grid */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 16px;
    }
    .stat-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 20px;
      text-align: center;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .stat-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    }
    .stat-number {
      font-size: 36px;
      font-weight: 900;
      line-height: 1;
      margin-bottom: 6px;
    }
    .stat-label {
      font-size: 11px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      font-weight: 700;
    }
    .stat-total .stat-number { color: var(--accent-blue); }
    .stat-critical .stat-number { color: var(--accent-red); }
    .stat-high .stat-number { color: var(--accent-orange); }
    .stat-medium .stat-number { color: var(--accent-yellow); }
    .stat-low .stat-number { color: var(--accent-cyan); }
    .stat-info .stat-number { color: var(--text-muted); }

    /* Service Table */
    .service-table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      font-size: 14px;
    }
    .service-table thead th {
      background: var(--bg-secondary);
      color: var(--text-secondary);
      font-weight: 700;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 12px 16px;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }
    .service-table thead th:first-child { border-radius: 8px 0 0 0; }
    .service-table thead th:last-child { border-radius: 0 8px 0 0; }
    .service-table tbody td {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
      color: var(--text-primary);
    }
    .service-table tbody tr:hover td { background: rgba(59, 130, 246, 0.04); }
    .service-badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 600;
      font-family: 'JetBrains Mono', monospace;
    }
    .service-badge-open {
      background: rgba(16, 185, 129, 0.15);
      color: #34d399;
      border: 1px solid rgba(16, 185, 129, 0.2);
    }
    .service-badge-name {
      background: rgba(59, 130, 246, 0.15);
      color: #60a5fa;
      border: 1px solid rgba(59, 130, 246, 0.2);
    }

    /* Findings */
    .finding {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 12px;
      margin-bottom: 16px;
      overflow: hidden;
      transition: border-color 0.3s ease;
    }
    .finding:hover { border-color: var(--border-hover); }
    .finding-header {
      padding: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--border);
      background: rgba(0, 0, 0, 0.2);
    }
    .finding-header h4 {
      font-size: 15px;
      font-weight: 700;
      color: var(--text-primary);
    }
    .finding-body { padding: 20px; }
    .finding-body p { color: var(--text-secondary); margin-bottom: 16px; font-size: 14px; }

    .finding-meta {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 16px;
    }
    .finding-meta-item {
      background: rgba(0, 0, 0, 0.2);
      border-radius: 8px;
      padding: 10px 14px;
    }
    .finding-meta-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-muted);
      font-weight: 700;
      margin-bottom: 4px;
    }
    .finding-meta-value {
      font-size: 13px;
      color: var(--text-primary);
      font-weight: 500;
    }

    /* Severity Badges */
    .badge {
      padding: 4px 12px;
      border-radius: 6px;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .badge-critical { background: rgba(239, 68, 68, 0.2); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.3); }
    .badge-high { background: rgba(249, 115, 22, 0.2); color: #fdba74; border: 1px solid rgba(249, 115, 22, 0.3); }
    .badge-medium { background: rgba(234, 179, 8, 0.2); color: #fde047; border: 1px solid rgba(234, 179, 8, 0.3); }
    .badge-low { background: rgba(6, 182, 212, 0.2); color: #67e8f9; border: 1px solid rgba(6, 182, 212, 0.3); }
    .badge-informational { background: rgba(100, 116, 139, 0.2); color: #94a3b8; border: 1px solid rgba(100, 116, 139, 0.3); }

    /* Code blocks */
    pre {
      background: #020617;
      color: #a7f3d0;
      padding: 16px;
      border-radius: 8px;
      font-family: 'JetBrains Mono', 'Fira Code', monospace;
      font-size: 12px;
      overflow-x: auto;
      border: 1px solid var(--border);
      line-height: 1.7;
    }

    /* Exploit box */
    .exploit-box {
      background: rgba(234, 179, 8, 0.06);
      border: 1px solid rgba(234, 179, 8, 0.15);
      border-left: 3px solid var(--accent-yellow);
      padding: 16px;
      border-radius: 0 8px 8px 0;
      margin-top: 12px;
    }
    .exploit-box h5 { color: #fde047; font-size: 13px; margin-bottom: 8px; font-weight: 700; }
    .exploit-box code {
      background: rgba(0, 0, 0, 0.3);
      padding: 2px 8px;
      border-radius: 4px;
      font-family: 'JetBrains Mono', monospace;
      font-size: 12px;
      color: #fef08a;
    }
    .exploit-box ul { padding-left: 16px; margin: 0; }
    .exploit-box li { color: #fef9c3; font-size: 13px; margin-bottom: 4px; }

    /* Host Section */
    .host-header {
      background: linear-gradient(135deg, rgba(59, 130, 246, 0.1), rgba(139, 92, 246, 0.05));
      border: 1px solid rgba(59, 130, 246, 0.15);
      padding: 16px 20px;
      border-radius: 10px;
      margin-bottom: 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .host-header h3 {
      font-size: 17px;
      font-weight: 700;
      color: var(--text-primary);
    }
    .host-header .host-count {
      background: var(--gradient-accent);
      color: white;
      padding: 4px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 700;
    }

    /* Config tags */
    .config-tags {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
    }
    .config-tag {
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 16px;
      font-size: 13px;
    }
    .config-tag .tag-label {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-muted);
      font-weight: 700;
      display: block;
      margin-bottom: 2px;
    }
    .config-tag .tag-value {
      color: var(--text-primary);
      font-weight: 600;
    }

    /* Empty State */
    .empty-state {
      text-align: center;
      padding: 48px 32px;
      color: var(--text-muted);
    }
    .empty-state .empty-icon { font-size: 48px; margin-bottom: 16px; }
    .empty-state h3 { color: var(--text-secondary); margin-bottom: 8px; font-size: 18px; }
    .empty-state p { font-size: 14px; max-width: 400px; margin: 0 auto; }

    /* Footer */
    .footer {
      text-align: center;
      padding: 32px;
      color: var(--text-muted);
      font-size: 12px;
      border-top: 1px solid var(--border);
      margin-top: 40px;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      .finding-meta { grid-template-columns: 1fr; }
      .header-meta { flex-direction: column; gap: 8px; }
    }
  </style>
</head>
<body>

<div class="header">
  <div class="header-inner">
    <div class="header-top">
      <div class="header-logo">🔍</div>
      <div>
        <h1>Metasploit Methodology Engine</h1>
        <div class="header-sub">Automated Penetration Testing Report</div>
      </div>
    </div>
    <div class="header-meta">
      <div class="header-meta-item">🎯 Target: <span><%= h(metadata[:target]) %></span></div>
      <div class="header-meta-item">⏱️ Duration: <span><%= metadata[:duration] %>s</span></div>
      <div class="header-meta-item">🕐 Started: <span><%= metadata[:start_time]&.strftime('%Y-%m-%d %H:%M:%S') rescue metadata[:start_time] %></span></div>
      <div class="header-meta-item">🏁 Ended: <span><%= metadata[:end_time]&.strftime('%Y-%m-%d %H:%M:%S') rescue metadata[:end_time] %></span></div>
    </div>
  </div>
</div>

<div class="container">

  <!-- Scan Configuration -->
  <% scan_opts = metadata[:scan_options] || {} %>
  <div class="card">
    <div class="card-title"><span class="icon">⚙️</span> Scan Configuration</div>
    <div class="config-tags">
      <div class="config-tag">
        <span class="tag-label">Profile</span>
        <span class="tag-value"><%= (scan_opts[:profile] || 'normal').to_s.upcase %></span>
      </div>
      <div class="config-tag">
        <span class="tag-label">Threads</span>
        <span class="tag-value"><%= scan_opts[:threads] || 1 %></span>
      </div>
      <div class="config-tag">
        <span class="tag-label">Brute-Force</span>
        <span class="tag-value"><%= scan_opts[:brute] ? '✅ ENABLED' : '❌ DISABLED' %></span>
      </div>
      <div class="config-tag">
        <span class="tag-label">Hosts Scanned</span>
        <span class="tag-value"><%= metadata[:hosts_scanned] || 0 %></span>
      </div>
      <div class="config-tag">
        <span class="tag-label">Services Found</span>
        <span class="tag-value"><%= metadata[:services_found] || 0 %></span>
      </div>
      <div class="config-tag">
        <span class="tag-label">Tool Version</span>
        <span class="tag-value">v<%= metadata[:tool_version] %></span>
      </div>
    </div>
  </div>

  <!-- Executive Summary -->
  <div class="card">
    <div class="card-title"><span class="icon">📊</span> Executive Summary</div>
    <div class="stats-grid">
      <div class="stat-card stat-total">
        <div class="stat-number"><%= sorted_findings.size %></div>
        <div class="stat-label">Total Findings</div>
      </div>
      <% sev_colors = { 'critical' => 'critical', 'high' => 'high', 'medium' => 'medium', 'low' => 'low', 'informational' => 'info' } %>
      <% Finding::SEVERITIES.each do |sev| %>
        <div class="stat-card stat-<%= sev_colors[sev] || 'info' %>">
          <div class="stat-number"><%= severity_summary[sev] || 0 %></div>
          <div class="stat-label"><%= sev.capitalize %></div>
        </div>
      <% end %>
    </div>
  </div>

  <% if metadata[:phase_zero] && !metadata[:phase_zero].empty? %>
  <!-- Phase 0: Target Discovery -->
  <div class="card">
    <div class="card-title"><span class="icon">🌐</span> Phase 0: Target Discovery & Resolution</div>
    <div class="stats-grid">
      <% if metadata[:phase_zero][:target_type] == :domain %>
        <div class="stat-card">
          <div class="stat-number" style="color: var(--accent-purple);"><%= metadata[:phase_zero][:subdomains_found] %></div>
          <div class="stat-label">Subdomains Found</div>
        </div>
      <% end %>
      <div class="stat-card">
        <div class="stat-number" style="color: var(--accent-green);"><%= metadata[:hosts_scanned] %></div>
        <div class="stat-label">Live Hosts</div>
      </div>
      <div class="stat-card">
        <div class="stat-number" style="color: var(--accent-red);"><%= metadata[:phase_zero][:dead_hosts] %></div>
        <div class="stat-label">Dead Hosts</div>
      </div>
      <div class="stat-card">
        <div class="stat-number" style="color: var(--accent-yellow);"><%= metadata[:phase_zero][:excluded_hosts] %></div>
        <div class="stat-label">Excluded</div>
      </div>
    </div>
  </div>
  <% end %>

  <!-- Discovered Services -->
  <% service_entries = metadata[:service_entries] || [] %>
  <% unless service_entries.empty? %>
  <div class="card">
    <div class="card-title"><span class="icon">🖧</span> Discovered Services (<%= service_entries.size %>)</div>
    <table class="service-table">
      <thead>
        <tr>
          <th>Host</th>
          <th>Port</th>
          <th>Protocol</th>
          <th>Service</th>
          <th>Info / Banner</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% service_entries.each do |svc| %>
          <tr>
            <td><strong><%= h(svc.host) %></strong></td>
            <td><span class="service-badge service-badge-open"><%= svc.port %></span></td>
            <td><%= h(svc.proto) %></td>
            <td><span class="service-badge service-badge-name"><%= h(svc.name.to_s.upcase) %></span></td>
            <td style="color: var(--text-secondary); font-size: 13px;"><%= h(svc.info.to_s.slice(0, 80)) %></td>
            <td><%= h(svc.status.to_s) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% end %>

  <!-- Detailed Findings -->
  <div class="card">
    <div class="card-title"><span class="icon">🛡️</span> Detailed Findings</div>

    <% if findings_by_host.empty? %>
      <div class="empty-state">
        <div class="empty-icon">🔒</div>
        <h3>No Vulnerabilities Discovered</h3>
        <p>No actionable findings were identified during this scan. The target appears to be well-hardened against automated enumeration.</p>
      </div>
    <% else %>
      <% findings_by_host.each do |host, host_findings| %>
        <div style="margin-top: 24px;">
          <div class="host-header">
            <h3>🖥️ <%= h(host) %></h3>
            <span class="host-count"><%= host_findings.size %> Finding<%= host_findings.size == 1 ? '' : 's' %></span>
          </div>

          <% host_findings.each do |f| %>
            <div class="finding">
              <div class="finding-header">
                <h4><%= h(f.title) %></h4>
                <span class="badge badge-<%= h(f.severity) %>"><%= h(f.severity) %></span>
              </div>
              <div class="finding-body">
                <p><%= h(f.description) %></p>

                <div class="finding-meta">
                  <div class="finding-meta-item">
                    <div class="finding-meta-label">Service</div>
                    <div class="finding-meta-value"><%= h(f.service.to_s.upcase) %> (Port <%= f.port %>)</div>
                  </div>
                  <div class="finding-meta-item">
                    <div class="finding-meta-label">Module</div>
                    <div class="finding-meta-value" style="font-family: 'JetBrains Mono', monospace; font-size: 12px;"><%= h(f.module_path) %></div>
                  </div>
                  <% unless f.impact.to_s.empty? %>
                  <div class="finding-meta-item">
                    <div class="finding-meta-label">Impact</div>
                    <div class="finding-meta-value"><%= h(f.impact) %></div>
                  </div>
                  <% end %>
                  <% unless f.remediation.to_s.empty? %>
                  <div class="finding-meta-item">
                    <div class="finding-meta-label">Remediation</div>
                    <div class="finding-meta-value"><%= h(f.remediation) %></div>
                  </div>
                  <% end %>
                </div>

                <% if f.exploits && f.exploits.any? %>
                  <div class="exploit-box">
                    <h5>🎯 Potential Metasploit Exploits Available</h5>
                    <ul>
                      <% f.exploits.each do |exp| %>
                        <li>
                          <code>use <%= h(exp[:fullname]) %></code> — <%= h(exp[:name]) %>
                          <span style="color: var(--text-muted); font-size: 11px; margin-left: 6px;">
                            (Rank: <%= exp[:rank] %>, Match: <%= h(exp[:confidence] || 'Possible') %>)
                          </span>
                        </li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>

                <% if f.evidence.is_a?(Array) && f.evidence.any? %>
                  <div style="margin-top: 16px;">
                    <div class="finding-meta-label" style="margin-bottom: 8px;">Evidence / Proof of Concept</div>
                    <% f.evidence.each do |ev| %>
                      <% content_to_show = ev.to_s %>
                      <% clean_content = content_to_show.lines.reject { |l| l.strip.empty? || l.match?(/Scanned \d+ of \d+ hosts|New in Metasploit/) }.map { |l| l.sub(/^\[\+\]\s+/, '').sub(/^\[\*\]\s+/, '').sub(/^\d+\.\d+\.\d+\.\d+:\d+\s+-\s+/, '').strip }.reject(&:empty?).join("\n") %>
                      <% display_text = clean_content.empty? ? content_to_show : clean_content %>
                      <% safe_text = display_text.gsub('<', '&lt;').gsub('>', '&gt;') %>
                      <% linked_text = safe_text.gsub(/(https?:\/\/[^\s]+)/, '<a href="\1" target="_blank" style="color: var(--accent-cyan); text-decoration: underline;">\1</a>') %>
                      <pre><%= linked_text.respond_to?(:html_safe) ? linked_text.html_safe : raw(linked_text) rescue linked_text %></pre>
                    <% end %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if metadata[:unmatched_services] && metadata[:unmatched_services].any? %>
  <!-- Unmatched Services -->
  <div class="card" style="border-color: rgba(234, 179, 8, 0.2);">
    <div class="card-title" style="color: var(--accent-yellow); border-bottom-color: rgba(234, 179, 8, 0.15);"><span class="icon">⚠️</span> Manual Review Required</div>
    <p style="color: var(--text-secondary); margin-bottom: 16px; font-size: 14px;">These services were discovered but have no matching playbook. They require manual enumeration.</p>
    <table class="service-table">
      <thead>
        <tr><th>Host</th><th>Port</th><th>Protocol</th><th>Service</th><th>Info</th></tr>
      </thead>
      <tbody>
        <% metadata[:unmatched_services].each do |svc| %>
          <tr>
            <td><%= h(svc.host) %></td>
            <td><%= svc.port %></td>
            <td><%= h(svc.proto) %></td>
            <td><%= h(svc.name) %></td>
            <td style="color: var(--text-secondary);"><%= h(svc.info) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <% end %>

</div>

<div class="footer">
  Generated by <%= metadata[:tool_name] %> v<%= metadata[:tool_version] %> on <%= Time.now.strftime('%Y-%m-%d %H:%M:%S %Z') %><br>
  <span style="color: var(--text-muted);">⚠️ CONFIDENTIAL — Authorized recipients only</span>
</div>

</body>
</html>
